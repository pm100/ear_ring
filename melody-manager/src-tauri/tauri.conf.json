{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1421",
    "distDir": "../dist"
  },
  "package": {
    "productName": "MelodyManager",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": false },
      "http": {
        "all": true,
        "scope": [
            "https://**",
            "http://**"
          ]
      },
      "fs": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.earring.melodymanager",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/256x256.png",
        "icons/512x512.png",
        "icons/icon.ico"
      ]
    },
    "security": { "csp": null },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Melody Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "fileDropEnabled": false
      }
    ],
    "systemTray": null
  }
}
