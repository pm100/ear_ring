{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "EarRing",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "http": { "all": true, "scope": ["https://tonejs.github.io/**"] }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.earring.desktop",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/256x256.png",
        "icons/512x512.png",
        "icons/icon.ico"
      ]
    },
    "security": { "csp": null },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Ear Ring",
        "width": 480,
        "height": 820,
        "minWidth": 400,
        "minHeight": 700,
        "fileDropEnabled": false
      }
    ],
    "systemTray": null
  }
}
